      setCpfError('CPF inválido');
      toast.error('Por favor, informe um CPF válido.');
      return;
    }

    setIsSubmitting(true);

    try {
      if (editData && editData.id) {
        await pb.collection('participantes').update(editData.id, formData, { $autoCancel: false });
        toast.success('Participante atualizado com sucesso!');
      } else {
        await pb.collection('participantes').create({
          ...formData,
          checkin: false
        }, { $autoCancel: false });
        toast.success('Participante cadastrado com sucesso!');
      }
      
      setFormData({
        nome: '',
        cpf: '',
        empresa: '',
        cargo: '',
        municipio: '',
        estado: '',
        tipo: 'participante',
        categoria: ''
      });
      
      if (onSaveComplete) {
        onSaveComplete();
      }
    } catch (error) {
      console.error('Error saving participant:', error);
      toast.error('Erro ao salvar participante. Tente novamente.');
    } finally {
      setIsSubmitting(false);
    }
  };

  return (
    <Card className="max-w-2xl mx-auto">
      <CardHeader>
