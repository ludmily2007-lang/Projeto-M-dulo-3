import React, { useState, useEffect } from 'react';
import { Plus, Trash2, Tag, AlertCircle, RefreshCw } from 'lucide-react';
import { Button } from '@/components/ui/button.jsx';
import { Input } from '@/components/ui/input.jsx';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card.jsx';
import { Skeleton } from '@/components/ui/skeleton.jsx';
import { toast } from 'sonner';
import pb from '@/lib/pocketbaseClient.js';

const CategoryManagement = () => {
  const [categories, setCategories] = useState([]);
  const [counts, setCounts] = useState({});
  const [newCategory, setNewCategory] = useState('');
  const [isLoading, setIsLoading] = useState(true);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [error, setError] = useState(null);

  const fetchCategoriesAndCounts = async () => {
    setIsLoading(true);
    setError(null);
    try {
      const records = await pb.collection('categorias').getFullList({
        sort: '-created',
        $autoCancel: false
      });
      setCategories(records);

      // Fetch participant counts for each category
      const countsObj = {};
      await Promise.all(
        records.map(async (cat) => {
          try {
            const res = await pb.collection('participantes').getList(1, 1, {
              filter: `categoria="${cat.id}"`,
              $autoCancel: false
            });
            countsObj[cat.id] = res.totalItems;
          } catch (err) {
            console.error(`Error fetching count for category ${cat.id}:`, err);
            countsObj[cat.id] = 0;
          }
        })
      );
      setCounts(countsObj);
    } catch (err) {
      console.error('Error fetching categories:', err);
      setError('Não foi possível carregar as categorias.');
      toast.error('Erro ao carregar categorias.');
    } finally {
      setIsLoading(false);
    }
  };

  useEffect(() => {
    fetchCategoriesAndCounts();
  }, []);

  const handleAddCategory = async (e) => {
    e.preventDefault();
    const categoryName = newCategory.trim();
    
    if (!categoryName) {
      toast.error('O nome da categoria é obrigatório.');
      return;
    }

    setIsSubmitting(true);
    try {
      await pb.collection('categorias').create({
        nome: categoryName
      }, { $autoCancel: false });
      
      toast.success('Categoria adicionada com sucesso!');
      setNewCategory('');
      fetchCategoriesAndCounts();
    } catch (err) {
      console.error('Full error response creating category:', err);
      
      if (err.status === 400) {
        const validationErrors = err.data?.data;
        if (validationErrors?.nome?.code === 'validation_not_unique') {
          toast.error('Já existe uma categoria com este nome.');
        } else {
          toast.error('Erro de validação. Verifique os dados informados.');
        }
      } else if (err.status === 403) {
        toast.error('Permissão negada. Você precisa estar autenticado no sistema.');
      } else {
        toast.error('Erro ao adicionar categoria. Tente novamente mais tarde.');
      }
    } finally {
      setIsSubmitting(false);
    }
  };

  const handleDeleteCategory = async (id, count) => {
    if (count > 0) {
      toast.error('Não é possível excluir uma categoria que possui participantes vinculados.');
      return;
    }

    try {
      await pb.collection('categorias').delete(id, { $autoCancel: false });
      toast.success('Categoria excluída.');
      setCategories(categories.filter(c => c.id !== id));
    } catch (err) {
      console.error('Error deleting category:', err);
      if (err.status === 403) {
        toast.error('Permissão negada para excluir categorias.');
      } else {
        toast.error('Erro ao excluir a categoria.');
      }
    }
  };

  if (error) {
    return (
      <Card>
        <CardContent className="py-8 text-center">
          <AlertCircle className="w-12 h-12 text-destructive mx-auto mb-4" />
          <h3 className="text-lg font-medium mb-2">Erro de Carregamento</h3>
          <p className="text-muted-foreground mb-4">{error}</p>
          <Button onClick={fetchCategoriesAndCounts}>
            <RefreshCw className="w-4 h-4 mr-2" />
            Tentar Novamente
          </Button>
        </CardContent>
      </Card>
    );
  }

  return (
    <Card>
      <CardHeader>
        <CardTitle className="flex items-center gap-2">
          <Tag className="w-5 h-5 text-primary" />
          Gerenciamento de Categorias
        </CardTitle>
        <CardDescription>
          Crie e gerencie categorias de participantes para o evento.
        </CardDescription>
      </CardHeader>
      <CardContent className="space-y-6">
        <form onSubmit={handleAddCategory} className="flex gap-3">
          <div className="flex-1">
            <Input
              placeholder="Nome da nova categoria (ex: VIP, Estudante)"
              value={newCategory}
              onChange={(e) => setNewCategory(e.target.value)}
              disabled={isSubmitting || isLoading}
              required
            />
          </div>
          <Button type="submit" disabled={isSubmitting || isLoading || !newCategory.trim()}>
            <Plus className="w-4 h-4 mr-2" />
            Adicionar
          </Button>
        </form>

        <div className="rounded-md border">
          <div className="divide-y">
            {isLoading ? (
              Array.from({ length: 3 }).map((_, i) => (
                <div key={i} className="p-4 flex justify-between items-center">
                  <Skeleton className="h-5 w-1/3" />
                  <Skeleton className="h-8 w-20" />
                </div>
              ))
            ) : categories.length === 0 ? (
