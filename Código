const CheckInParticipants = () => {
  const [participants, setParticipants] = useState([]);
  const [isLoading, setIsLoading] = useState(true);
  const [stats, setStats] = useState({
    total: 0,
    checkedIn: 0,
    percentage: 0,
    firstCheckIn: '-',
    lastCheckIn: '-'
  });

  const fetchParticipants = async () => {
    setIsLoading(true);
    try {
      const records = await pb.collection('participantes').getFullList({
        sort: '-data_checkin',
        $autoCancel: false
      });
      
      setParticipants(records);
      calculateStats(records);
    } catch (error) {
      console.error('Error fetching participants for dashboard:', error);
      toast.error('Erro ao carregar dados do dashboard');
    } finally {
      setIsLoading(false);
    }
  };

  const calculateStats = (data) => {
    const total = data.length;
    const checkedInList = data.filter(p => p.checkin);
    const checkedIn = checkedInList.length;
    const percentage = total > 0 ? Math.round((checkedIn / total) * 100) : 0;
    
    let firstCheckIn = '-';
    let lastCheckIn = '-';

    if (checkedInList.length > 0) {
      const times = checkedInList.map(p => new Date(p.data_checkin).getTime());
      const minTime = new Date(Math.min(...times));
      const maxTime = new Date(Math.max(...times));
      
      const formatTime = (date) => new Intl.DateTimeFormat('pt-BR', {
        hour: '2-digit', minute: '2-digit'
      }).format(date);

      firstCheckIn = formatTime(minTime);
      lastCheckIn = formatTime(maxTime);
    }

    setStats({ total, checkedIn, percentage, firstCheckIn, lastCheckIn });
  };

  useEffect(() => {
    fetchParticipants();
  }, []);

  const handleGenerateReport = () => {
    const checkedInParticipants = participants.filter(p => p.checkin);
    if (checkedInParticipants.length === 0) {
      toast.warning('Não há participantes com check-in para gerar o relatório.');
      return;
    }
    
    try {
      generateReport(checkedInParticipants, stats);
      toast.success('Relatório gerado com sucesso!');
    } catch (error) {
      console.error('Error generating report:', error);
      toast.error('Erro ao gerar relatório.');
    }
  };

  const checkedInParticipants = participants.filter(p => p.checkin);

  const formatDateTime = (dateString) => {
    if (!dateString) return '-';
    const date = new Date(dateString);
    return new Intl.DateTimeFormat('pt-BR', {
      day: '2-digit', month: '2-digit', year: 'numeric',
      hour: '2-digit', minute: '2-digit', second: '2-digit'
