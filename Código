        nome: '',
        cpf: '',
        empresa: '',
        cargo: '',
        municipio: '',
        estado: '',
        tipo: 'participante',
        categoria: ''
      });
    }
    setCpfError('');
  }, [editData]);

  const handleChange = (e) => {
    const { name, value } = e.target;
    
    if (name === 'cpf') {
      const formatted = formatCPF(value);
      setFormData(prev => ({ ...prev, [name]: formatted }));
      if (formatted.length === 14) {
        setCpfError(validateCPF(formatted) ? '' : 'CPF inválido');
      } else {
        setCpfError('');
      }
    } else {
      setFormData(prev => ({ ...prev, [name]: value }));
    }
  };

  const handleSelectChange = (name, value) => {
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    
    // Validating required fields
    if (!formData.nome || !formData.cpf || !formData.empresa || !formData.cargo || 
        !formData.municipio || !formData.estado || !formData.tipo || !formData.categoria) {
      toast.error('Por favor, preencha todos os campos obrigatórios, incluindo a Categoria.');
