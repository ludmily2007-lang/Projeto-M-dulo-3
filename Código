                  id="cpf" 
                  name="cpf" 
                  value={formData.cpf} 
                  onChange={handleChange} 
                  placeholder="000.000.000-00"
                  maxLength={14}
                  disabled={isSubmitting}
                  className={cpfError ? 'border-destructive focus-visible:ring-destructive' : ''}
                  required
                />
